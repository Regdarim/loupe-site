{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/studio",
      "destination": "/studio/index.html"
    },
    {
      "source": "/studio/((?!.*\\..*).+)",
      "destination": "/studio/index.html"
    },
    {
      "source": "/((?!studio)(?!.*\\..*).+)",
      "destination": "/index.html"
    }
  ]
}
